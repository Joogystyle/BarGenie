# Public browser variables
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional compatibility variable used by some checks/utilities
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Browser-safe route target in production app is /api/chat, so this can stay unset.
# Keep only if you intentionally want direct browser calls (not recommended).
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# Server-only webhook relay variables
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
